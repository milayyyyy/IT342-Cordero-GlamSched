<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/body_bg"
    android:orientation="vertical">

    <!-- App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_header_premium"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp">

        <!-- Left: Avatar with gold ring -->
        <FrameLayout
            android:id="@+id/btnFeedAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_avatar_gold_ring"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_avatar_gradient" />

                <ImageView
                    android:id="@+id/ivFeedAvatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Profile avatar" />

                <TextView
                    android:id="@+id/tvFeedAvatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </FrameLayout>

        <!-- Right: Welcome + Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFeedWelcomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.20"
                android:text="WELCOME BACK"
                android:textColor="#F2C76C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvFeedWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFeedNotifications"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notifications"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_popup_reminder"
            android:tint="@color/white" />
    </LinearLayout>

    <!-- Search + Category bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingBottom="14dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_pill"
                android:hint="Search artists or services..."
                android:inputType="text"
                android:paddingStart="44dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink_black"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="14dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="@color/text_hint" />
        </FrameLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_chip_pill_selected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="All"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipHair"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Hair"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipMakeup"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Makeup"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipNails"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Nails"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipSkincare"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Skincare"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipLashes"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Lashes"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipBrows"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Brows"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipWaxing"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Waxing"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipMassage"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Massage"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipOther"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_pill_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Other"
                    android:textColor="@color/ink_black"
                    android:textSize="13sp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Feed RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/tvFeedEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No services found"
            android:textColor="@color/ink_black"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Try a different category or search term."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
