<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlamSched"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.register.RegisterActivity" />
        <activity android:name=".ui.loginsuccess.LoginSuccessActivity" />
        <activity android:name=".ui.dashboard.DashboardActivity" />
        <activity android:name=".ui.dashboard.ClientDashboardActivity" />
        <activity android:name=".ui.dashboard.ArtistDashboardActivity" />
        <activity android:name=".ui.booking.ArtistProfileActivity" />
        <activity android:name=".ui.booking.SelectDateActivity" />
        <activity android:name=".ui.booking.SelectTimeActivity" />
        <activity android:name=".ui.booking.AdditionalNotesActivity" />
        <activity android:name=".ui.booking.BookingConfirmationActivity" />

    </application>
</manifest>
